        \"stage\": state.stage,\n            \"load\": state.cognitive_load,\n            \"resonance\": state.resonance\n        })\n        \n        logger.info(f\"Cognitive State Updated [{session_id}]: {state.intent_vector} | Stage: {state.stage} (Load: {state.cognitive_load:.2f})\")",
