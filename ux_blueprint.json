  "ux_evaluation_wave": {
    "cognitive_load_analysis": "The user needs to understand the system as a series of interconnected microservices, each with specific functionalities. Mental models should focus on input/output streams, configuration parameters, and observable metrics. The system should abstract away underlying infrastructure complexity.",
    "affordance_map": [
      {
        "element": "primary action buttons (e.g., 'Deploy', 'Configure', 'View Logs')",
        "visual_cue": "Prominent placement, distinct color contrast (e.g., brand-primary), clear iconography, and hover states.",
        "interaction": "Clickable, providing immediate feedback on press and state change."
      },
      {
        "element": "data visualization components (charts, graphs)",
        "visual_cue": "Clear axes labels, tooltips on hover, distinct color palettes for multiple data series, and dynamic updates.",
        "interaction": "Hover to reveal details, potential for drill-down or filtering."
      },
      {
        "element": "navigation elements (tabs, sidebar links)",
        "visual_cue": "Underlined active states, clear labels, consistent placement.",
        "interaction": "Clickable, triggering content changes without full page reload."
      },
      {
        "element": "input fields and controls (text areas, dropdowns, toggles)",
