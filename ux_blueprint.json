        "interaction": "Editable, with immediate visual feedback on input and validation."
      }
    ],
    "gsap_animation_plan": [
      {
        "transition": "Page/section transitions",
        "animation": "Subtle fade-in/slide-up with slight stagger for content blocks to reduce perceived load.",
        "trigger": "Navigation changes, data loading."
      },
      {
        "transition": "Button click feedback",
        "animation": "Micro-scale scale-down/up on press, followed by a subtle color/border change to indicate processing. Subsequent state change animation (e.g., checkmark, spinner).",
        "trigger": "All primary and secondary interactive elements."
      },
      {
        "transition": "Data loading and updates",
        "animation": "Skeleton loaders or shimmering effects for new content areas, with smooth transitions for chart updates.",
        "trigger": "Asynchronous data fetches."
      },
      {
        "transition": "Expansion/collapse of information panels",
        "animation": "Smooth height transition with optional slight fade.",
        "trigger": "Accordions, expandable logs, detailed views."
      }
    ],
    "accessibility_checklist": [
      "WCAG 2.2 AA Level: Color contrast ratio minimum 4.5:1 for normal text and 3:1 for large text.",
      "Semantic HTML5: Use appropriate tags (nav, main, article, aside, header, footer, section).",
      "ARIA attributes: Use aria-label, aria-labelledby, aria-describedby, aria-haspopup, aria-expanded where necessary for interactive elements and dynamic content.",
      "Keyboard navigability: All interactive elements focusable and operable via keyboard (tab order logical, visible focus indicator).",
      "Focus management: Ensure focus is appropriately managed during dynamic content changes.",
      "Screen reader compatibility: Test with major screen readers (NVDA, JAWS, VoiceOver).",
      "Resizable text: Ensure UI remains usable when text is resized up to 200%.",
