def test_audit_logging():
    """Test that audit events are logged."""
    # Ensure log file is empty before test
    if os.path.exists(config.audit_log_path):
        os.remove(config.audit_log_path)

    component = FullCycleSI()
    input_data = {"id": 3, "value": "auditable", "object_id": "obj-456"}
    component.process_data(input_data)

    with open(config.audit_log_path, "r") as f:
        logs = f.readlines()

    assert len(logs) == 1
    log_entry = json.loads(logs[0])
    assert log_entry["event"] == "data_processed"
    assert log_entry["details"]["input"]["id"] == 3

