def _verify_test_results_integrity(test_results: dict):
    """
    Automated, deterministic, and auditable sanity checks on test results.
    Checks for data integrity and bias before reporting.
    """
    print("Verifying integrity of test results...")
    assert isinstance(test_results, dict), "Test results must be a dictionary."
    assert "passed" in test_results and "failed" in test_results, "Test results missing 'passed' or 'failed' counts."
    assert isinstance(test_results["passed"], int) and test_results["passed"] >= 0, "Invalid 'passed' count."
    assert isinstance(test_results["failed"], int) and test_results["failed"] >= 0, "Invalid 'failed' count."
    print("Test results integrity verified.")

