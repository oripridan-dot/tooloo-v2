{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claudio Engram (C+I)",
  "description": "Unified Cognitive Engram for Real-time Audio Synchronization",
  "type": "object",
  "properties": {
    "context": {
      "type": "object",
      "properties": {
        "what": { "type": "string", "enum": ["AUDIO_STREAM", "CLOCK_SYNC", "PATHWAY_A", "PATHWAY_B"] },
        "when": { "type": "string", "format": "date-time" },
        "where": { "type": "string", "description": "Node/ISP Topology ID" },
        "who": { "type": "string", "description": "Musician/Role identifier" },
        "how": { "type": "string", "enum": ["ASIO_DIRECT", "CORE_AUDIO", "DANTE_BYPASS", "WEB_RTC_FALLBACK"] },
        "why": { "type": "string", "const": "GROOVE_PRESERVATION" }
      },
      "required": ["what", "when", "where", "who", "how", "why"]
    },
    "intent": {
      "type": "object",
      "properties": {
        "temporal": {
          "type": "object",
          "properties": {
            "target_buffer_ms": { "type": "number", "minimum": 0, "maximum": 50 },
            "clock_drift_compensation_ns": { "type": "integer" },
            "jitter_buffer_strategy": { "type": "string", "enum": ["STRICT_LOCK", "ADAPTIVE", "AGGRESSIVE_DROP"] },
            "phase_alignment_priority": { "type": "number", "minimum": 0, "label": "Dimension: Speed/Accuracy" }
          },
          "required": ["target_buffer_ms", "jitter_buffer_strategy"]
        },
        "relational": {
          "type": "object",
          "properties": {
            "signal_role": { "type": "string", "enum": ["DRUMS", "BASS", "VOCALS", "GTR", "KEYS", "SYNTH"] },
            "actuation_priority": { "type": "number", "minimum": 0, "maximum": 1.0, "description": "Network weighting based on rhythmic importance" },
            "master_clock_offset_ms": { "type": "number" },
            "asymmetry_tolerance": { "type": "boolean", "description": "Allow monitoring delay to keep local sync" }
          },
          "required": ["signal_role", "actuation_priority"]
        },
        "adaptation": {
          "type": "object",
          "properties": {
            "threshold_em_delta": { "type": "number", "description": "Trigger shift if EM stability drops below X" },
            "fallback_codec": { "type": "string", "enum": ["OPUS_HQ", "OPUS_LQ", "UNCOMPRESSED_PCM"] }
          }
        }
      },
      "required": ["temporal", "relational"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "psyche_bank_ref": { "type": "string" },
        "decompiler_checksum": { "type": "string" }
      }
    }
  }
}
