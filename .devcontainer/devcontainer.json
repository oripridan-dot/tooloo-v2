{
  "name": "TooLoo Sovereign Hub",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/google-cloud-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.debugpy",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "secrets": {
    "GEMINI_API_KEY": {},
    "ANTHROPIC_API_KEY": {},
    "GCP_PROJECT_ID": {}
  },
  "postCreateCommand": "pip install -q -r requirements.txt && pip install -e . -q && echo '✅ TooLoo Sovereign Hub ready — run ./deploy.sh to deploy'",
  "remoteUser": "vscode",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Sovereign Hub (local preview)",
      "onAutoForward": "notify"
    }
  }
}
