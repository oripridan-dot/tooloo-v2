# TooLoo V2 — DEV MODE overrides
# ────────────────────────────────────────────────────────────────────────────
# Usage:
#   cp .env.dev .env      (start a fresh dev session)
#   set -a && source .env.dev && set +a   (overlay onto existing .env)
#
# These values loosen production thresholds so iterative development sessions
# don't trip the circuit-breaker, refinement gate, or sandbox promotion guard.
# ALL values are overridable via the real .env — these are the dev defaults.
# NEVER commit .env.dev with real credentials filled in.
# ────────────────────────────────────────────────────────────────────────────

# ── Google Cloud / Vertex AI ─────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_DEFAULT_MODEL=gemini-2.5-flash

# ── Gemini Developer API (fallback when Vertex ADC is absent) ────────────────
GEMINI_API_KEY=
# GEMINI_MODEL derives from VERTEX_DEFAULT_MODEL — do not set manually

# ── Anthropic Claude via Vertex AI ───────────────────────────────────────────
# Only available in us-east5 and europe-west1.  Leave blank to disable.
ANTHROPIC_VERTEX_REGION=us-east5

# ── Model Garden ─────────────────────────────────────────────────────────────
# DEV: consensus enabled + short TTL so model garden refreshes every 5 min
CROSS_MODEL_CONSENSUS_ENABLED=true
MODEL_GARDEN_CACHE_TTL=300

# ── Governor Dashboard ───────────────────────────────────────────────────────
STUDIO_HOST=0.0.0.0
STUDIO_PORT=8002
# DEV: auto-reload on file saves
STUDIO_RELOAD=true

# ── Circuit breaker ───────────────────────────────────────────────────────────
# DEV: lower threshold so valid dev mandates don't trip the breaker during
#      iterative sessions.  Production: CIRCUIT_BREAKER_THRESHOLD=0.85
CIRCUIT_BREAKER_THRESHOLD=0.60
# DEV: allow 10 consecutive failures before tripping.  Production: 3
CIRCUIT_BREAKER_MAX_FAILS=10

# ── Executor ─────────────────────────────────────────────────────────────────
# DEV: double fan-out workers for faster parallel execution.  Production: 8
EXECUTOR_MAX_WORKERS=16

# ── Refinement Loop ──────────────────────────────────────────────────────────
# DEV: relax thresholds so pipelines aren't blocked during fast iteration.
#   Production defaults: SLOW_THRESHOLD_MS=500  WARN=0.70  FAIL=0.50
REFINEMENT_SLOW_THRESHOLD_MS=2000
REFINEMENT_WARN_THRESHOLD=0.45
REFINEMENT_FAIL_THRESHOLD=0.25

# ── Sandbox ──────────────────────────────────────────────────────────────────
# DEV: lower promote threshold so features at 50%+ readiness are PROVEN.
#   Production: SANDBOX_PROMOTE_THRESHOLD=0.72
SANDBOX_PROMOTE_THRESHOLD=0.50
SANDBOX_MAX_WORKERS=8

# ── Refinement Supervisor ────────────────────────────────────────────────────
# DEV: allow more retries before healing overhead kicks in.  Production: 3
NODE_FAIL_THRESHOLD=6

# ── N-Stroke Engine ──────────────────────────────────────────────────────────
# DEV: more strokes for complex mandates to converge.  Production: 7
N_STROKE_MAX_STROKES=12

# ── Router ────────────────────────────────────────────────────────────────────
# DEV: hedge only on truly uncertain routes.  Production: _HEDGE_THRESHOLD=0.65
ROUTER_HEDGE_THRESHOLD=0.35

# ── Autonomous Loop ──────────────────────────────────────────────────────────
# DEV: faster self-improvement feedback.  Production: 90s
AUTO_LOOP_INTERVAL_SECONDS=30
AUTO_LOOP_FLOOR_SECONDS=10

# ── Autonomous Execution ─────────────────────────────────────────────────────
AUTONOMOUS_EXECUTION_ENABLED=true
AUTONOMOUS_CONFIDENCE_THRESHOLD=0.99

# ── Local SLM (Tier-0 lock_model override) ───────────────────────────────────
# Leave blank unless running Ollama or compatible local inference server.
LOCAL_SLM_MODEL=local/llama-3.2-3b-instruct
LOCAL_SLM_ENDPOINT=http://127.0.0.1:11434/api/generate
