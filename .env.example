# TooLoo V2 environment — copy to .env and fill in values
# NEVER commit .env to git

# ── LLM ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── GitHub ────────────────────────────────────────────────────────────────────
# PAT with: repo, workflow, read:org
GITHUB_TOKEN=your_github_pat_here

# ── Governor Dashboard ────────────────────────────────────────────────────────
STUDIO_HOST=0.0.0.0
STUDIO_PORT=8002
STUDIO_RELOAD=false

# ── Circuit breaker ───────────────────────────────────────────────────────────
# Confidence below this threshold fires the breaker flag (Law 19)
CIRCUIT_BREAKER_THRESHOLD=0.85
CIRCUIT_BREAKER_MAX_FAILS=3

# ── Engram DB ─────────────────────────────────────────────────────────────────
ENGRAM_DB_PATH=tooloo_v2.db
