<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <title>TooLoo Studio — powered by Buddy</title>
  <style>
    :root {
      --primary: #6C63FF;
      --primary-dim: rgba(108, 99, 255, 0.12);
      --primary-glow: rgba(108, 99, 255, 0.35);
      --surface: #1A1A2E;
      --surface-alt: #16213E;
      --surface-card: #1f1f38;
      --border: #2a2a48;
      --text: #E0E0E0;
      --muted: #7a7a9a;
      --accent: #F5A623;
      --danger: #FF4757;
      --success: #2ED573;
      --warn: #FFA502;
      --font: 'Inter', system-ui, sans-serif;
      --mono: 'JetBrains Mono', 'Fira Code', monospace;
      --radius: 8px;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html,
    body {
      height: 100%;
      background: var(--surface);
      color: var(--text);
      font-family: var(--font);
      font-size: 14px;
    }

    #app {
      display: grid;
      grid-template-columns: 220px 1fr;
      grid-template-rows: 52px 1fr;
      height: 100vh;
      overflow: hidden;
    }

    #topbar {
      grid-column: 1/-1;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 20px;
      background: var(--surface-alt);
      border-bottom: 1px solid var(--border);
      z-index: 10;
    }

    .logo-mark {
      width: 28px;
      height: 28px;
      border-radius: 7px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 13px;
      color: #fff;
      flex-shrink: 0;
    }

    .topbar-title {
      font-weight: 700;
      font-size: 15px;
    }

    .topbar-title em {
      color: var(--accent);
      font-style: normal;
    }

    .topbar-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .breaker-pill {
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 20px;
      background: rgba(46, 213, 115, 0.12);
      color: var(--success);
      border: 1px solid rgba(46, 213, 115, 0.25);
      cursor: default;
      user-select: none;
      letter-spacing: .04em;
    }

    .breaker-pill.open {
      background: rgba(255, 71, 87, .12);
      color: var(--danger);
      border-color: rgba(255, 71, 87, .25);
    }

    .btn-sm {
      font-size: 11px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 6px;
      background: var(--primary-dim);
      color: var(--primary);
      border: 1px solid var(--primary-glow);
      cursor: pointer;
      transition: background .15s;
    }

    .btn-sm:hover {
      background: rgba(108, 99, 255, 0.22);
    }

    .conn-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--success);
      box-shadow: 0 0 6px var(--success);
    }

    .conn-dot.off {
      background: var(--muted);
      box-shadow: none;
    }

    #sidebar {
      background: var(--surface-alt);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      padding: 16px 10px;
      gap: 4px;
      overflow-y: auto;
    }

    .nav-section {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .1em;
      color: var(--muted);
      padding: 10px 8px 4px;
      text-transform: uppercase;
    }

    .nav-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 10px;
      border-radius: var(--radius);
      cursor: pointer;
      color: var(--muted);
      font-size: 13px;
      font-weight: 500;
      transition: background .12s, color .12s;
      border: none;
      background: transparent;
      width: 100%;
      text-align: left;
    }

    .nav-btn:hover {
      background: var(--primary-dim);
      color: var(--text);
    }

    .nav-btn.active {
      background: var(--primary-dim);
      color: var(--primary);
      font-weight: 700;
    }

    .nav-btn .icon {
      font-size: 16px;
      flex-shrink: 0;
    }

    .nav-badge {
      margin-left: auto;
      font-size: 10px;
      font-weight: 700;
      background: var(--primary);
      color: #fff;
      border-radius: 10px;
      padding: 1px 6px;
      min-width: 18px;
      text-align: center;
    }

    .sidebar-footer {
      margin-top: auto;
      padding-top: 12px;
      border-top: 1px solid var(--border);
    }

    .agent-card {
      background: var(--surface-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 12px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .agent-name {
      font-weight: 700;
      font-size: 13px;
      color: var(--text);
    }

    .pulse {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--success);
      flex-shrink: 0;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(46, 213, 115, .4)
      }

      50% {
        opacity: .8;
        box-shadow: 0 0 0 4px transparent
      }
    }

    #main {
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .view {
      display: none;
      flex-direction: column;
      height: 100%;
      overflow: hidden;
    }

    .view.active {
      display: flex;
    }

    .view-header {
      padding: 16px 24px 12px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }

    .view-title {
      font-size: 16px;
      font-weight: 700;
    }

    .view-sub {
      font-size: 12px;
      color: var(--muted);
      margin-top: 1px;
    }

    /* Chat */
    #chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 20px 24px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .msg {
      display: flex;
      flex-direction: column;
      gap: 4px;
      max-width: 80%;
    }

    .msg.user {
      align-self: flex-end;
      align-items: flex-end;
    }

    .msg.buddy {
      align-self: flex-start;
      align-items: flex-start;
    }

    .msg-avatar {
      width: 26px;
      height: 26px;
      border-radius: 6px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      flex-shrink: 0;
    }

    .msg-row {
      display: flex;
      align-items: flex-end;
      gap: 8px;
    }

    .msg.user .msg-row {
      flex-direction: row-reverse;
    }

    .bubble {
      padding: 10px 14px;
      border-radius: 14px;
      line-height: 1.6;
      font-size: 14px;
      word-wrap: break-word;
    }

    .msg.user .bubble {
      background: var(--primary);
      color: #fff;
      border-bottom-right-radius: 3px;
    }

    .msg.buddy .bubble {
      background: var(--surface-card);
      border: 1px solid var(--border);
      color: var(--text);
      border-bottom-left-radius: 3px;
    }

    .bubble.thinking {
      color: var(--muted);
      font-style: italic;
    }

    .msg-meta {
      font-size: 11px;
      color: var(--muted);
      padding: 0 4px;
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    .intent-tag {
      font-weight: 700;
      font-size: 10px;
      padding: 1px 7px;
      border-radius: 10px;
      background: var(--primary-dim);
      color: var(--primary);
      letter-spacing: .05em;
    }

    .intent-tag.blocked {
      background: rgba(255, 71, 87, .12);
      color: var(--danger);
    }

    .conf-bar-wrap {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .conf-bar {
      width: 60px;
      height: 4px;
      border-radius: 2px;
      background: var(--border);
      overflow: hidden;
    }

    .conf-bar-fill {
      height: 100%;
      border-radius: 2px;
      background: var(--success);
    }

    .conf-bar-fill.warn {
      background: var(--warn);
    }

    .conf-bar-fill.low {
      background: var(--danger);
    }

    .tribunal-block {
      margin-top: 8px;
      padding: 8px 10px;
      background: rgba(255, 71, 87, .08);
      border: 1px solid rgba(255, 71, 87, .2);
      border-radius: 6px;
      font-size: 12px;
      font-family: var(--mono);
      color: var(--danger);
    }

    .tribunal-block.clean {
      background: rgba(46, 213, 115, .06);
      border-color: rgba(46, 213, 115, .2);
      color: var(--success);
    }

    .plan-waves {
      margin-top: 10px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .wave-row {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .wave-label {
      font-size: 10px;
      font-weight: 700;
      color: var(--muted);
      font-family: var(--mono);
      min-width: 42px;
    }

    .wave-node {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 4px;
      background: var(--primary-dim);
      color: var(--primary);
      border: 1px solid var(--primary-glow);
      font-family: var(--mono);
    }

    .wave-sep {
      color: var(--accent);
      font-size: 12px;
      font-weight: 700;
    }

    .scope-block {
      margin-top: 8px;
      padding: 8px 10px;
      background: rgba(108, 99, 255, 0.07);
      border: 1px solid rgba(108, 99, 255, 0.2);
      border-radius: 6px;
      font-size: 11px;
      font-family: var(--mono);
      color: var(--primary);
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .scope-block-title {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .06em;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 2px;
    }

    .scope-tag {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 4px;
      background: var(--primary-dim);
      color: var(--primary);
      margin-right: 4px;
    }

    .refine-block {
      margin-top: 8px;
      padding: 8px 10px;
      border-radius: 6px;
      font-size: 11px;
      font-family: var(--mono);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .refine-block.pass {
      background: rgba(46, 213, 115, .06);
      border: 1px solid rgba(46, 213, 115, .2);
      color: var(--success);
    }

    .refine-block.warn {
      background: rgba(255, 165, 0, .07);
      border: 1px solid rgba(255, 165, 0, .2);
      color: var(--warn);
    }

    .refine-block.fail {
      background: rgba(255, 71, 87, .08);
      border: 1px solid rgba(255, 71, 87, .2);
      color: var(--danger);
    }

    .refine-rec {
      font-size: 11px;
      opacity: .85;
    }

    .conv-plan-block {
      margin-top: 10px;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .conv-plan-title {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .06em;
      color: var(--muted);
      text-transform: uppercase;
      font-family: var(--mono);
      margin-bottom: 2px;
    }

    .conv-phase-row {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .conv-phase-label {
      font-size: 10px;
      font-weight: 700;
      color: var(--accent);
      font-family: var(--mono);
      min-width: 38px;
    }

    .conv-phase-node {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 4px;
      background: rgba(0, 210, 255, .08);
      color: var(--accent);
      border: 1px solid rgba(0, 210, 255, .2);
      font-family: var(--mono);
    }

    .tone-badge {
      font-size: 10px;
      font-weight: 600;
      padding: 1px 7px;
      border-radius: 10px;
      background: rgba(0, 210, 255, .1);
      color: var(--accent);
      border: 1px solid rgba(0, 210, 255, .2);
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .model-label {
      font-size: 10px;
      color: var(--muted);
      opacity: .7;
      font-family: var(--mono);
    }

    .suggestions-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-top: 8px;
      padding-left: 34px;
    }

    .suggestion-chip {
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 20px;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      cursor: pointer;
      transition: border-color .15s, color .15s;
      white-space: nowrap;
    }

    .suggestion-chip:hover {
      border-color: var(--primary);
      color: var(--primary);
    }

    #chat-input-area {
      flex-shrink: 0;
      padding: 14px 24px;
      border-top: 1px solid var(--border);
      background: var(--surface-alt);
      display: flex;
      gap: 10px;
      align-items: flex-end;
    }

    #msg-input {
      flex: 1;
      background: var(--surface);
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 13px;
      font-family: var(--font);
      font-size: 14px;
      resize: none;
      outline: none;
      line-height: 1.5;
      max-height: 120px;
      min-height: 42px;
      overflow-y: auto;
    }

    #msg-input:focus {
      border-color: var(--primary);
    }

    #send-btn {
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      padding: 0 20px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      height: 42px;
      flex-shrink: 0;
      transition: opacity .15s;
    }

    #send-btn:hover {
      opacity: .85;
    }

    #send-btn:disabled {
      opacity: .35;
      cursor: default;
    }

    /* Feed */
    #feed-body {
      flex: 1;
      overflow-y: auto;
      padding: 16px 24px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .feed-empty,
    .dag-empty,
    .bank-empty {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 13px;
      flex-direction: column;
      gap: 8px;
    }

    .feed-event {
      background: var(--surface-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 14px;
      border-left: 3px solid var(--primary);
      animation: slideIn .2s ease;
    }

    .feed-event.tribunal {
      border-left-color: var(--danger);
    }

    .feed-event.plan {
      border-left-color: var(--accent);
    }

    .feed-event.execution {
      border-left-color: var(--success);
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(-6px)
      }

      to {
        opacity: 1;
        transform: translateY(0)
      }
    }

    .feed-event-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 4px;
    }

    .feed-type-badge {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .06em;
      padding: 1px 7px;
      border-radius: 10px;
      background: var(--primary-dim);
      color: var(--primary);
    }

    .feed-type-badge.tribunal {
      background: rgba(255, 71, 87, .12);
      color: var(--danger);
    }

    .feed-type-badge.plan {
      background: rgba(245, 166, 35, .1);
      color: var(--accent);
    }

    .feed-type-badge.execution {
      background: rgba(46, 213, 115, .1);
      color: var(--success);
    }

    .feed-type-badge.scope {
      background: rgba(108, 99, 255, .12);
      color: var(--primary);
    }

    .feed-type-badge.refinement {
      background: rgba(245, 166, 35, .1);
      color: var(--accent);
    }

    .feed-mid {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
    }

    .feed-ts {
      margin-left: auto;
      font-size: 11px;
      color: var(--muted);
    }

    .feed-body-text {
      font-size: 12px;
      color: var(--text);
      opacity: .85;
      font-family: var(--mono);
      white-space: pre-wrap;
      word-break: break-all;
      max-height: 80px;
      overflow: hidden;
    }

    /* DAG */
    #dag-body {
      flex: 1;
      overflow: auto;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .dag-stats {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .dag-stat {
      background: var(--surface-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 16px;
      display: flex;
      flex-direction: column;
      gap: 2px;
      min-width: 110px;
    }

    .dag-stat-val {
      font-size: 22px;
      font-weight: 800;
      color: var(--primary);
    }

    .dag-stat-label {
      font-size: 11px;
      color: var(--muted);
    }

    #dag-canvas {
      background: var(--surface-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
      overflow-x: auto;
    }

    .dag-nodes {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .dag-wave-row {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .dag-wave-label {
      font-size: 11px;
      font-weight: 700;
      font-family: var(--mono);
      color: var(--muted);
      min-width: 54px;
    }

    .dag-node-box {
      padding: 8px 16px;
      border-radius: 8px;
      border: 1.5px solid var(--primary);
      background: var(--primary-dim);
      color: var(--primary);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .dag-arrow {
      font-size: 16px;
      color: var(--muted);
    }

    /* PsycheBank */
    #bank-body {
      flex: 1;
      overflow-y: auto;
      padding: 16px 24px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .bank-rule {
      background: var(--surface-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 12px 16px;
      border-left: 3px solid var(--danger);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .bank-rule-header {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .bank-rule-id {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 700;
      color: var(--primary);
    }

    .bank-rule-cat {
      font-size: 10px;
      font-weight: 700;
      padding: 1px 7px;
      border-radius: 10px;
      background: rgba(255, 71, 87, .1);
      color: var(--danger);
      letter-spacing: .05em;
    }

    .bank-rule-enf {
      font-size: 10px;
      font-weight: 700;
      padding: 1px 7px;
      border-radius: 10px;
      background: rgba(255, 71, 87, .15);
      color: var(--danger);
    }

    .bank-rule-src {
      margin-left: auto;
      font-size: 11px;
      color: var(--muted);
    }

    .bank-rule-desc {
      font-size: 13px;
      color: var(--text);
      opacity: .85;
    }

    .bank-rule-pattern {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--warn);
      background: rgba(255, 165, 0, .07);
      padding: 4px 8px;
      border-radius: 4px;
    }

    /* Sandbox Lab */
    .sb-card {
      background: var(--surface-card);
      border-radius: var(--radius);
      padding: 14px;
      transition: border-color .15s;
    }

    .sb-state-pill {
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 10px;
      letter-spacing: .05em;
      text-transform: uppercase;
    }

    .sb-dim-bar-wrap {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
    }

    .sb-dim-bar {
      flex: 1;
      height: 3px;
      background: var(--border);
      border-radius: 2px;
      overflow: hidden;
    }

    .sb-dim-bar-fill {
      height: 100%;
      border-radius: 2px;
    }

    .sb-spawn-input {
      width: 100%;
      background: var(--surface);
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 8px 10px;
      font-size: 13px;
      outline: none;
      font-family: var(--font);
    }

    .sb-spawn-input:focus {
      border-color: var(--primary);
    }

    .roadmap-item-box {
      background: var(--surface-card);
      border-radius: var(--radius);
      padding: 6px 10px;
      font-size: 11px;
      cursor: default;
      transition: border-color .12s;
    }

    ::-webkit-scrollbar {
      width: 4px;
      height: 4px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 4px;
    }
  </style>
</head>

<body>
  <div id="app">

    <div id="topbar">
      <div class="logo-mark">T</div>
      <div class="topbar-title">TooLoo <em>Studio</em></div>
      <div style="width:1px;height:20px;background:var(--border);margin:0 4px"></div>
      <span style="font-size:12px;color:var(--muted)">powered by</span>
      <span style="font-size:12px;font-weight:700;color:var(--accent)">🤖 Buddy</span>
      <div class="topbar-right">
        <span class="breaker-pill" id="breaker-pill">CLOSED</span>
        <button class="btn-sm" id="reset-btn">Reset Breaker</button>
        <div class="conn-dot off" id="conn-dot" title="SSE connection"></div>
      </div>
    </div>

    <nav id="sidebar">
      <div class="nav-section">Workspace</div>
      <button class="nav-btn active" data-view="chat"><span class="icon">💬</span> Buddy Chat</button>
      <button class="nav-btn" data-view="feed">
        <span class="icon">📡</span> Live Feed
        <span class="nav-badge" id="feed-badge" style="display:none">0</span>
      </button>
      <div class="nav-section">System</div>
      <button class="nav-btn" data-view="dag"><span class="icon">🕸</span> DAG View</button>
      <button class="nav-btn" data-view="bank">
        <span class="icon">🧬</span> PsycheBank
        <span class="nav-badge" id="bank-badge" style="display:none">0</span>
      </button>
      <button class="nav-btn" data-view="self-improve"><span class="icon">🔁</span> Self-Improve</button>
      <button class="nav-btn" data-view="sandbox">
        <span class="icon">🧪</span> Sandbox Lab
        <span class="nav-badge" id="sandbox-badge" style="display:none">0</span>
      </button>
      <div class="sidebar-footer">
        <div class="agent-card">
          <div class="agent-name">🤖 Buddy</div>
          <div style="display:flex;gap:6px;align-items:center">
            <div class="pulse"></div><span style="font-size:11px;color:var(--muted)" id="agent-status">Online ·
              Ready</span>
          </div>
          <div style="font-size:10px;color:var(--muted);margin-top:2px" id="engine-ver">TooLoo V2</div>
        </div>
      </div>
    </nav>

    <main id="main">

      <!-- CHAT -->
      <section class="view active" id="view-chat">
        <div class="view-header">
          <div>
            <div class="view-title">💬 Buddy Chat</div>
            <div class="view-sub">Send mandates — Buddy routes, plans, executes, and defends.</div>
          </div>
        </div>
        <div id="chat-messages">
          <div class="msg buddy">
            <div class="msg-row">
              <div class="msg-avatar">🤖</div>
              <div class="bubble">
                Hey! I'm <strong>Buddy</strong> — your TooLoo V2 build host.<br>
                Tell me what you need: <em>build a feature, fix a bug, audit a module, explore ideas…</em><br>
                I remember our conversation, plan each response as a DAG, and intercept anything unsafe.
              </div>
            </div>
          </div>
        </div>
        <div id="chat-input-area">
          <textarea id="msg-input" rows="1"
            placeholder="Give Buddy a mandate… (Enter to send, Shift+Enter for newline)"></textarea>
          <button id="send-btn">Send →</button>
        </div>
      </section>

      <!-- FEED -->
      <section class="view" id="view-feed">
        <div class="view-header">
          <div>
            <div class="view-title">📡 Live Event Feed</div>
            <div class="view-sub">Real-time SSE stream — route · tribunal · plan · execution events</div>
          </div>
          <button class="btn-sm" id="clear-feed-btn" style="margin-left:auto">Clear</button>
        </div>
        <div id="feed-body">
          <div class="feed-empty" id="feed-empty">
            <span style="font-size:28px">📡</span>
            Waiting for events… send a mandate in the Chat view.
          </div>
        </div>
      </section>

      <!-- DAG -->
      <section class="view" id="view-dag">
        <div class="view-header">
          <div>
            <div class="view-title">🕸 DAG View</div>
            <div class="view-sub">Cognitive graph snapshot — nodes and dependency edges</div>
          </div>
          <button class="btn-sm" id="refresh-dag-btn" style="margin-left:auto">↻ Refresh</button>
        </div>
        <div id="dag-body">
          <div class="dag-empty" id="dag-empty">
            <span style="font-size:28px">🕸</span>
            No DAG nodes yet. Send a mandate to build the graph.
          </div>
          <div id="dag-content" style="display:none;flex-direction:column;gap:20px">
            <div class="dag-stats" id="dag-stats"></div>
            <div id="dag-canvas">
              <div class="dag-nodes" id="dag-nodes"></div>
            </div>
          </div>
        </div>
      </section>

      <!-- PSYCHEBANK -->
      <section class="view" id="view-bank">
        <div class="view-header">
          <div>
            <div class="view-title">🧬 PsycheBank</div>
            <div class="view-sub">Tribunal VastLearn rule store — OWASP violations captured mid-flight</div>
          </div>
          <button class="btn-sm" id="refresh-bank-btn" style="margin-left:auto">↻ Refresh</button>
        </div>
        <div id="bank-body">
          <div class="bank-empty" id="bank-empty">
            <span style="font-size:28px">🧬</span>
            No rules captured yet. Send a poisoned mandate to populate.
          </div>
          <div id="bank-rules" style="display:contents"></div>
        </div>
      </section>

      <!-- SELF-IMPROVE -->
      <section class="view" id="view-self-improve">
        <div class="view-header">
          <div>
            <div class="view-title">🔁 Self-Improvement</div>
            <div class="view-sub">TooLoo V2 audits each engine component through its own pipeline — Router → JIT →
              Tribunal → Scope → Execute → Refine</div>
          </div>
          <button class="btn-sm" id="run-si-btn" style="margin-left:auto;background:var(--primary);color:#fff">▶ Run
            Cycle</button>
        </div>
        <div id="si-body">
          <div id="si-idle"
            style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:12px;color:var(--muted)">
            <span style="font-size:36px">🔁</span>
            <div>Click <strong>Run Cycle</strong> to start the self-improvement pipeline.</div>
            <div style="font-size:11px">8 components · 3 waves · full Router → JIT → Tribunal → Scope → Execute → Refine
            </div>
          </div>
          <div id="si-spinner"
            style="display:none;align-items:center;justify-content:center;height:100%;gap:10px;color:var(--muted)">
            <div class="pulse"></div><span>Running self-improvement cycle…</span>
          </div>
          <div id="si-result"
            style="display:none;flex-direction:column;gap:16px;padding:16px;overflow-y:auto;height:100%">
            <div id="si-summary" style="display:flex;gap:16px;flex-wrap:wrap"></div>
            <div id="si-recs"></div>
            <div id="si-assessments"></div>
          </div>
        </div>
      </section>

      <!-- SANDBOX LAB -->
      <section class="view" id="view-sandbox">
        <div class="view-header">
          <div>
            <div class="view-title">🧪 Sandbox Lab</div>
            <div class="view-sub">Graph + vector backed · up to 25 parallel · Route → JIT → Tribunal → Scope → Execute →
              Refine → 9-Dimension Score</div>
          </div>
          <div style="margin-left:auto;display:flex;gap:8px;align-items:center">
            <button class="btn-sm" id="roadmap-toggle-btn">🗺 Roadmap</button>
            <button class="btn-sm" id="spawn-toggle-btn">＋ Spawn</button>
            <button class="btn-sm" id="run-roadmap-btn"
              style="background:var(--primary);color:#fff;border-color:var(--primary)">▶ Run Roadmap</button>
          </div>
        </div>

        <!-- Roadmap collapsible panel -->
        <div id="roadmap-panel"
          style="display:none;border-bottom:1px solid var(--border);padding:14px 24px;flex-shrink:0;max-height:320px;overflow-y:auto">
          <div id="roadmap-loading" style="color:var(--muted);font-size:12px">Loading roadmap…</div>
          <div id="roadmap-content" style="display:none;flex-direction:column;gap:6px"></div>
        </div>

        <!-- Spawn form collapsible panel -->
        <div id="spawn-panel"
          style="display:none;border-bottom:1px solid var(--border);padding:14px 24px;flex-shrink:0;background:var(--surface-alt)">
          <div style="display:flex;gap:10px;align-items:flex-start;flex-wrap:wrap">
            <div style="flex:0 0 200px">
              <div style="font-size:11px;color:var(--muted);margin-bottom:4px">Feature Title</div>
              <input id="spawn-title-input" type="text" class="sb-spawn-input"
                placeholder="e.g. Adaptive confidence gates" />
            </div>
            <div style="flex:1;min-width:260px">
              <div style="font-size:11px;color:var(--muted);margin-bottom:4px">Feature Description</div>
              <textarea id="spawn-text-input" rows="2" class="sb-spawn-input" style="resize:none"
                placeholder="Describe the feature to test in a sandbox…"></textarea>
            </div>
            <div style="display:flex;align-items:flex-end;padding-bottom:2px">
              <button id="do-spawn-btn" class="btn-sm"
                style="background:var(--primary);color:#fff;border-color:var(--primary);height:36px;padding:0 18px">▶
                Spawn</button>
            </div>
          </div>
          <div id="spawn-status" style="margin-top:6px;font-size:11px;color:var(--muted)"></div>
        </div>

        <!-- Sandbox cards -->
        <div id="sandbox-body"
          style="flex:1;overflow-y:auto;padding:16px 24px;display:flex;flex-direction:column;gap:10px">
          <div id="sandbox-empty"
            style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:12px;color:var(--muted)">
            <span style="font-size:40px">🧪</span>
            <div style="text-align:center">No sandboxes yet.<br>Click <strong>▶ Run Roadmap</strong> to test all 10
              features in parallel, or <strong>＋ Spawn</strong> to test a single feature.</div>
            <div style="font-size:11px;text-align:center;max-width:420px;color:var(--muted)">Full pipeline per sandbox:
              Vector Dedup → Router → JIT SOTA → Tribunal → Scope → Execute → Refine → 9-Dimension Scoring</div>
          </div>
          <div id="sandbox-list" style="display:flex;flex-direction:column;gap:10px"></div>
        </div>
      </section>

    </main>
  </div>

  <script>
    (() => {
      'use strict';

      const navBtns = document.querySelectorAll('.nav-btn[data-view]');
      const views = document.querySelectorAll('.view');

      function showView(id) {
        views.forEach(v => v.classList.toggle('active', v.id === 'view-' + id));
        navBtns.forEach(b => b.classList.toggle('active', b.dataset.view === id));
        if (id === 'dag') loadDag();
        if (id === 'bank') loadBank();
        if (id === 'self-improve') resetSIIdle();
        if (id === 'sandbox') loadSandboxes();
      }
      navBtns.forEach(b => b.addEventListener('click', () => showView(b.dataset.view)));

      async function refreshBreaker() {
        try {
          const d = await (await fetch('/v2/router-status')).json();
          const pill = document.getElementById('breaker-pill');
          const open = d.circuit_open;
          pill.textContent = (open ? 'OPEN' : 'CLOSED') + ' ' + d.consecutive_failures + '/' + d.max_fails;
          pill.className = 'breaker-pill' + (open ? ' open' : '');
          document.getElementById('agent-status').textContent = open ? 'Circuit OPEN — reset needed' : 'Online · Ready';
        } catch { }
      }

      document.getElementById('reset-btn').addEventListener('click', async () => {
        await fetch('/v2/router-reset', { method: 'POST' });
        refreshBreaker();
        appendBuddyMsg('Circuit breaker reset. Ready to go. 🟢', null);
      });

      let feedCount = 0;
      let _sseDelay = 2000;
      function connectSSE() {
        const dot = document.getElementById('conn-dot');
        const statusEl = document.getElementById('agent-status');
        const es = new EventSource('/v2/events');
        es.onopen = () => {
          dot.classList.remove('off');
          _sseDelay = 2000;
          statusEl.textContent = 'Online · Ready';
        };
        es.onerror = () => {
          dot.classList.add('off');
          es.close();
          const wait = Math.min(_sseDelay, 30000);
          _sseDelay = Math.min(_sseDelay * 2, 30000);
          statusEl.textContent = 'Reconnecting in ' + (wait / 1000).toFixed(0) + 's…';
          setTimeout(connectSSE, wait);
        };
        es.onmessage = (e) => {
          try {
            const ev = JSON.parse(e.data);
            if (ev.type !== 'heartbeat') pushFeed(ev);
            if (ev.type === 'sandbox' && ev.report) addSandboxCard(ev.report);
            if (ev.type === 'roadmap_run') { loadRoadmap(); }
          } catch { }
        };
      }

      const feedBody = document.getElementById('feed-body');
      const feedEmpty = document.getElementById('feed-empty');
      const feedBadge = document.getElementById('feed-badge');

      function pushFeed(ev) {
        feedEmpty.style.display = 'none';
        feedCount++;
        const active = document.querySelector('.view.active')?.id;
        if (active !== 'view-feed') { feedBadge.style.display = ''; feedBadge.textContent = feedCount; }
        const typeMap = { route: '', tribunal: 'tribunal', plan: 'plan', execution: 'execution', scope: 'scope', refinement: 'refinement', conversation: 'plan', sandbox: 'plan', roadmap_run: 'execution' };
        const cls = typeMap[ev.type] || '';
        const card = document.createElement('div');
        card.className = 'feed-event ' + cls;
        card.innerHTML =
          '<div class="feed-event-header">' +
          '<span class="feed-type-badge ' + cls + '">' + ev.type.toUpperCase() + '</span>' +
          '<span class="feed-mid">' + esc(ev.mandate_id || '') + '</span>' +
          '<span class="feed-ts">' + new Date().toLocaleTimeString() + '</span>' +
          '</div>' +
          '<div class="feed-body-text">' + esc(summary(ev)) + '</div>';
        feedBody.prepend(card);
      }

      function summary(ev) {
        if (ev.type === 'route') {
          const r = ev.route || {};
          return 'Intent: ' + r.intent + '  conf: ' + ((r.confidence || 0) * 100).toFixed(0) + '%\n"' + (r.buddy_line || '').slice(0, 80) + '"';
        }
        if (ev.type === 'tribunal') {
          const t = ev.result || {};
          return 'passed:' + t.passed + '  poison:' + t.poison_detected + '  healed:' + t.heal_applied + '  vastlearn:' + t.vast_learn_triggered + '\nviolations: ' + ((t.violations || []).join(', ') || 'none');
        }
        if (ev.type === 'plan') return 'waves: ' + (ev.waves || []).map((w, i) => 'W' + (i + 1) + '[' + w.join('|') + ']').join(' → ');
        if (ev.type === 'execution') return (ev.results || []).map(r => r.mandate_id + ': ' + (r.success ? '✓' : '✗') + ' (' + r.latency_ms + 'ms)').join('\n');
        if (ev.type === 'scope') {
          const sc = ev.scope || {};
          return '🔍 ' + (sc.scope_summary || '') + '\nstrategy:' + sc.strategy + '  workers:' + sc.recommended_workers + '  risk_surface:' + sc.risk_surface;
        }
        if (ev.type === 'refinement') {
          const ref = ev.report || {};
          return (ref.verdict === 'pass' ? '✓' : ref.verdict === 'warn' ? '⚠' : '✗') +
            ' verdict:' + ref.verdict + '  ' + ref.succeeded + '/' + ref.total + ' passed' +
            '  avg:' + (ref.avg_latency_ms || 0).toFixed(1) + 'ms' +
            (ref.recommendations && ref.recommendations.length ? '\n➤ ' + ref.recommendations[0] : '');
        }
        if (ev.type === 'conversation') {
          const c = ev.conversation || {};
          const plan = c.plan || {};
          return 'session:' + (ev.session_id || '').slice(0, 12) +
            '  intent:' + (c.intent || '?') +
            '  tone:' + (c.tone || '?') +
            '  model:' + (c.model_used || '?') +
            '  phases:' + (plan.waves || 0) +
            (plan.needs_clarification ? '  [clarification]' : '') +
            '\n"' + (c.response_text || '').slice(0, 90) + '"';
        }
        return JSON.stringify(ev).slice(0, 120);
      }

      document.getElementById('clear-feed-btn').addEventListener('click', () => {
        feedCount = 0; feedBadge.style.display = 'none';
        feedBody.innerHTML = ''; feedBody.appendChild(feedEmpty); feedEmpty.style.display = '';
      });
      navBtns.forEach(b => b.addEventListener('click', () => {
        if (b.dataset.view === 'feed') feedBadge.style.display = 'none';
        if (b.dataset.view === 'sandbox') { const sb = document.getElementById('sandbox-badge'); if (sb) sb.style.display = 'none'; }
      }));

      async function loadDag() {
        try {
          const d = await (await fetch('/v2/dag')).json();
          const empty = document.getElementById('dag-empty');
          const content = document.getElementById('dag-content');
          if (!d.nodes || !d.nodes.length) { empty.style.display = ''; content.style.display = 'none'; return; }
          empty.style.display = 'none'; content.style.display = 'flex';
          document.getElementById('dag-stats').innerHTML =
            stat(d.node_count, 'Nodes') + stat(d.edge_count, 'Edges') + stat('✓', 'Acyclic');
          const edges = d.edges || [];
          const placed = new Set(); let remaining = [...d.nodes]; const waves = [];
          while (remaining.length) {
            const wave = remaining.filter(n => edges.filter(e => e.to === n).map(e => e.from).every(p => placed.has(p)));
            if (!wave.length) { waves.push(remaining); break; }
            waves.push(wave); wave.forEach(n => placed.add(n)); remaining = remaining.filter(n => !placed.has(n));
          }
          document.getElementById('dag-nodes').innerHTML = waves.map((wave, wi) =>
            '<div class="dag-wave-row">' +
            '<span class="dag-wave-label">Wave ' + (wi + 1) + '</span>' +
            wave.map((n, ni) =>
              (ni > 0 ? '<span class="dag-arrow">‖</span>' : '') +
              '<div class="dag-node-box"><span style="color:var(--muted);font-size:10px">W' + (wi + 1) + '</span>' + esc(n) + '</div>'
            ).join('') +
            '</div>' +
            (wi < waves.length - 1 ? '<div style="padding-left:54px;color:var(--muted);font-size:16px">↓</div>' : '')
          ).join('');
        } catch (e) { document.getElementById('dag-empty').textContent = 'Error: ' + e.message; }
      }
      function stat(v, l) { return '<div class="dag-stat"><div class="dag-stat-val">' + v + '</div><div class="dag-stat-label">' + l + '</div></div>'; }
      document.getElementById('refresh-dag-btn').addEventListener('click', loadDag);

      async function loadBank() {
        try {
          const d = await (await fetch('/v2/psyche-bank')).json();
          const rules = d.rules || [];
          const empty = document.getElementById('bank-empty');
          const el = document.getElementById('bank-rules');
          const badge = document.getElementById('bank-badge');
          if (rules.length) { badge.style.display = ''; badge.textContent = rules.length; }
          if (!rules.length) { empty.style.display = ''; el.innerHTML = ''; return; }
          empty.style.display = 'none';
          el.innerHTML = rules.map(r =>
            '<div class="bank-rule">' +
            '<div class="bank-rule-header">' +
            '<span class="bank-rule-id">' + esc(r.id) + '</span>' +
            '<span class="bank-rule-cat">' + esc(r.category) + '</span>' +
            '<span class="bank-rule-enf">' + esc(r.enforcement) + '</span>' +
            '<span class="bank-rule-src">source: ' + esc(r.source) + '</span>' +
            '</div>' +
            '<div class="bank-rule-desc">' + esc(r.description) + '</div>' +
            '<div class="bank-rule-pattern">pattern: ' + esc(r.pattern) + '</div>' +
            '</div>'
          ).join('');
        } catch (e) { document.getElementById('bank-empty').textContent = 'Error: ' + e.message; }
      }
      document.getElementById('refresh-bank-btn').addEventListener('click', loadBank);

      const chatMessages = document.getElementById('chat-messages');
      const msgInput = document.getElementById('msg-input');
      const sendBtn = document.getElementById('send-btn');

      // Persistent session ID for multi-turn memory
      let _sessionId = sessionStorage.getItem('buddy_session_id');
      if (!_sessionId) {
        _sessionId = 'web-' + Math.random().toString(36).slice(2, 14);
        sessionStorage.setItem('buddy_session_id', _sessionId);
      }

      msgInput.addEventListener('input', () => { msgInput.style.height = 'auto'; msgInput.style.height = Math.min(msgInput.scrollHeight, 120) + 'px'; });
      msgInput.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } });
      sendBtn.addEventListener('click', send);

      function scrollChat() { chatMessages.scrollTop = chatMessages.scrollHeight; }

      // Click a suggestion chip -> pre-fill input and send
      // Exposed on window so inline onclick handlers in dynamically created chips can reach it.
      window.useChip = function useChip(btn) {
        const text = btn.textContent.trim().replace(/\?$/, '');
        msgInput.value = text;
        msgInput.dispatchEvent(new Event('input'));
        send();
      };

      function appendUserMsg(text) {
        const el = document.createElement('div'); el.className = 'msg user';
        el.innerHTML = '<div class="msg-row"><div class="bubble">' + esc(text) + '</div></div>';
        chatMessages.appendChild(el); scrollChat();
      }

      function appendBuddyMsg(text, data) {
        const el = document.createElement('div'); el.className = 'msg buddy';
        let inner;
        if (!data) {
          inner = '<div class="bubble">' + esc(text) + '</div>';
        } else {
          const r = data.route || {};
          const t = data.tribunal_result || {};
          const conv = data.conversation || {};
          const conf = typeof r.confidence === 'number' ? r.confidence : 0;
          const pct = (conf * 100).toFixed(0) + '%';
          const fc = conf >= 0.85 ? '' : conf >= 0.5 ? 'warn' : 'low';
          const blocked = r.intent === 'BLOCKED' || r.circuit_open === true;

          // Main response text: prefer rich conv.response_text, fall back to buddy_line
          const mainText = esc(conv.response_text || r.buddy_line || text);

          // Tribunal block
          const tribunalHtml = t.poison_detected ?
            '<div class="tribunal-block">&#x2695; Tribunal: ' + esc((t.violations || []).join(', ')) + ' \u2014 healed \xb7 VastLearn captured</div>' :
            (data.mandate_id ? '<div class="tribunal-block clean">\u2713 Tribunal: no violations</div>' : '');

          // Scope evaluation block (from /v2/mandate)
          const sc = data.scope || {};
          const scopeHtml = sc.scope_summary
            ? '<div class="scope-block">' +
            '<div class="scope-block-title">\uD83D\uDD2D Action Scope Evaluation</div>' +
            '<div>' + esc(sc.scope_summary) + '</div>' +
            '</div>'
            : '';

          // Conversation plan phases (from /v2/chat)
          const cp = conv.plan || {};
          const convPlanHtml = (cp.phases && cp.phases.length)
            ? '<div class="conv-plan-block">' +
            '<div class="conv-plan-title">Conversation plan (' + cp.waves + ' wave' + (cp.waves !== 1 ? 's' : '') + ')</div>' +
            cp.phases.map(p =>
              '<div class="conv-phase-row"><span class="conv-phase-label">W' + (p.wave + 1) + '</span>' +
              '<span class="conv-phase-node">' + esc(p.name) + '</span>' +
              '</div>'
            ).join('') +
            '</div>'
            : '';

          // Execution wave plan (from /v2/mandate)
          const execPlanHtml = (!convPlanHtml && (data.plan || []).length)
            ? '<div class="plan-waves"><div style="font-size:11px;color:var(--muted);margin-bottom:2px;font-family:var(--mono)">Execution plan (' + data.plan.length + ' wave' + (data.plan.length !== 1 ? 's' : '') + ')</div>' +
            data.plan.map((w, i) => '<div class="wave-row"><span class="wave-label">W' + (i + 1) + '</span>' + w.map((n, ni) => (ni > 0 ? '<span class="wave-sep">\u2016</span>' : '') + '<span class="wave-node">' + esc(n) + '</span>').join('') + '</div>').join('') +
            '</div>'
            : '';

          // Refinement report (from /v2/mandate)
          const ref = data.refinement || {};
          const refHtml = ref.verdict
            ? '<div class="refine-block ' + esc(ref.verdict) + '">' +
            (ref.verdict === 'pass' ? '\u2713' : ref.verdict === 'warn' ? '\u26a0' : '\u2717') +
            ' Refinement: ' + ref.succeeded + '/' + ref.total + ' passed' +
            ' \xb7 avg ' + (ref.avg_latency_ms || 0).toFixed(1) + 'ms' +
            (ref.rerun_advised ? ' \xb7 re-run advised' : '') +
            (ref.recommendations && ref.recommendations.length
              ? '<div class="refine-rec">' + esc(ref.recommendations[0]) + '</div>'
              : '') +
            '</div>'
            : '';

          // Tone badge + model label (from /v2/chat)
          const toneHtml = conv.tone
            ? '<span class="tone-badge">' + esc(conv.tone) + '</span>'
            : '';
          const modelHtml = conv.model_used
            ? '<span class="model-label">via ' + esc(conv.model_used) + '</span>'
            : '';

          // Suggestion chips (from /v2/chat)
          const suggsHtml = (conv.suggestions && conv.suggestions.length)
            ? '<div class="suggestions-row">' +
            conv.suggestions.map(s =>
              '<button class="suggestion-chip" onclick="useChip(this)">' + esc(s) + '</button>'
            ).join('') +
            '</div>'
            : '';

          inner =
            '<div class="bubble">' + mainText + tribunalHtml + scopeHtml + convPlanHtml + execPlanHtml + refHtml + '</div>' +
            '<div class="msg-meta">' +
            (blocked
              ? '<span class="intent-tag blocked">CIRCUIT OPEN</span> hit <strong>Reset Breaker</strong> to resume'
              : '<span class="intent-tag">' + esc(r.intent || '?') + '</span>' +
              '<div class="conf-bar-wrap"><div class="conf-bar"><div class="conf-bar-fill ' + fc + '" style="width:' + Math.round(conf * 100) + '%"></div></div><span>' + pct + '</span></div>' +
              toneHtml + modelHtml +
              (data.latency_ms != null ? '<span>' + data.latency_ms + 'ms</span>' : '')
            ) + '</div>' +
            suggsHtml;
        }
        el.innerHTML = '<div class="msg-row"><div class="msg-avatar">🤖</div>' + inner + '</div>';
        chatMessages.appendChild(el); scrollChat(); return el;
      }

      async function send() {
        const text = msgInput.value.trim(); if (!text) return;
        msgInput.value = ''; msgInput.style.height = 'auto'; sendBtn.disabled = true;
        appendUserMsg(text);
        const thinkEl = document.createElement('div'); thinkEl.className = 'msg buddy';
        thinkEl.innerHTML = '<div class="msg-row"><div class="msg-avatar">🤖</div><div class="bubble thinking">Thinking…</div></div>';
        chatMessages.appendChild(thinkEl); scrollChat();
        const doFetch = () => fetch('/v2/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text, session_id: _sessionId }),
        });
        try {
          let res;
          try { res = await doFetch(); }
          catch { await new Promise(r => setTimeout(r, 1500)); res = await doFetch(); }
          const data = await res.json();
          thinkEl.remove();
          appendBuddyMsg('', data);
          if (data.tribunal_result?.vast_learn_triggered) loadBank();
        } catch (err) {
          const isNet = err.message.toLowerCase().includes('fetch') || err.message.toLowerCase().includes('network');
          const msg = isNet
            ? '⚠ Network error — server unreachable. Check your connection and try again.'
            : '⚠ Error: ' + err.message;
          const bubble = thinkEl.querySelector('.bubble');
          bubble.classList.remove('thinking');
          bubble.innerHTML = esc(msg) + '<br><button style="margin-top:8px;font-size:11px;padding:3px 10px;border-radius:5px;background:var(--primary-dim);color:var(--primary);border:1px solid var(--primary-glow);cursor:pointer" onclick="this.closest(\'div.msg\').remove();document.getElementById(\'msg-input\').value=' + JSON.stringify(JSON.stringify(text)) + ';document.getElementById(\'send-btn\').click()">↩ Retry</button>';
        }
        sendBtn.disabled = false; refreshBreaker();
      }

      async function loadHealth() {
        try {
          const d = await (await fetch('/v2/health')).json();
          document.getElementById('engine-ver').textContent = 'TooLoo V' + (d.version || '2') + ' · ' + (d.components?.psyche_bank || '');
        } catch { }
      }

      function esc(s) { return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

      // ── Self-Improvement panel ──────────────────────────────────────────────
      function resetSIIdle() {
        document.getElementById('si-idle').style.display = 'flex';
        document.getElementById('si-spinner').style.display = 'none';
        document.getElementById('si-result').style.display = 'none';
      }

      document.getElementById('run-si-btn').addEventListener('click', async () => {
        document.getElementById('si-idle').style.display = 'none';
        document.getElementById('si-spinner').style.display = 'flex';
        document.getElementById('si-result').style.display = 'none';
        try {
          const resp = await fetch('/v2/self-improve', { method: 'POST' });
          const data = await resp.json();
          renderSI(data.self_improvement);
        } catch (e) {
          document.getElementById('si-spinner').style.display = 'none';
          document.getElementById('si-idle').style.display = 'flex';
          document.getElementById('si-idle').querySelector('div').textContent = 'Error: ' + e.message;
        }
      });

      function verdictColour(v) {
        return v === 'pass' ? 'var(--success)' : v === 'warn' ? 'var(--warn)' : 'var(--danger)';
      }

      function renderSI(r) {
        document.getElementById('si-spinner').style.display = 'none';
        const result = document.getElementById('si-result');
        result.style.display = 'flex';

        // Summary bar
        const vc = verdictColour(r.refinement_verdict);
        document.getElementById('si-summary').innerHTML =
          siStat(r.components_assessed, 'Components') +
          siStat(r.waves_executed, 'Waves') +
          siStat(r.total_signals, 'JIT Signals') +
          siStat(((r.refinement_success_rate || 0) * 100).toFixed(0) + '%', 'Pass Rate') +
          siStat(r.latency_ms.toFixed(0) + 'ms', 'Latency') +
          '<div style="background:var(--surface-card);border:1px solid ' + vc + ';border-radius:var(--radius);padding:8px 14px;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:80px">' +
          '<div style="font-size:18px;font-weight:700;color:' + vc + '">' + esc(r.refinement_verdict.toUpperCase()) + '</div>' +
          '<div style="font-size:10px;color:var(--muted)">Verdict</div></div>';

        // Top recommendations
        const recs = r.top_recommendations || [];
        document.getElementById('si-recs').innerHTML = recs.length
          ? '<div style="font-weight:600;margin-bottom:8px">📋 Top Recommendations</div>' +
          '<ol style="padding-left:20px;display:flex;flex-direction:column;gap:6px">' +
          recs.map(rec => '<li style="color:var(--text);font-size:12px">' + esc(rec) + '</li>').join('') +
          '</ol>'
          : '';

        // Per-component assessments
        const assessments = r.assessments || [];
        document.getElementById('si-assessments').innerHTML =
          '<div style="font-weight:600;margin-bottom:8px">🔬 Component Assessments</div>' +
          assessments.map(a => {
            const bc = (a.boosted_confidence * 100).toFixed(0);
            const oc = (a.original_confidence * 100).toFixed(0);
            const pass = a.execution_success;
            const border = pass ? 'var(--success)' : 'var(--danger)';
            return '<div style="background:var(--surface-card);border:1px solid ' + border + ';border-radius:var(--radius);padding:12px;margin-bottom:10px">' +
              '<div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:6px">' +
              '<strong>' + esc(a.component.toUpperCase()) + '</strong>' +
              '<span style="font-size:11px;color:var(--muted)">' + esc(a.description) + '</span>' +
              '<span style="font-size:11px;background:var(--primary-dim);color:var(--primary);padding:2px 6px;border-radius:4px">' + esc(a.intent) + '</span>' +
              '<span style="font-size:11px;color:var(--muted)">' + oc + '% → ' + bc + '% conf</span>' +
              '<span style="font-size:11px;color:var(--muted)">source:' + esc(a.jit_source) + '</span>' +
              '<span style="font-size:11px;color:' + (pass ? 'var(--success)' : 'var(--danger)') + '">' + (pass ? '✓ tribunal' : '✗ tribunal') + '</span>' +
              '</div>' +
              (a.jit_signals && a.jit_signals.length
                ? '<div style="font-size:11px;color:var(--muted);margin-bottom:4px">JIT signals: ' + a.jit_signals.map(s => esc(s)).join(' · ') + '</div>'
                : '') +
              (a.suggestions && a.suggestions.length
                ? '<div style="display:flex;flex-wrap:wrap;gap:6px">' +
                a.suggestions.map(s => '<span style="font-size:11px;background:var(--surface-alt);border:1px solid var(--border);border-radius:4px;padding:2px 8px">' + esc(s) + '</span>').join('') +
                '</div>'
                : '') +
              '</div>';
          }).join('');
      }

      function siStat(v, l) {
        return '<div style="background:var(--surface-card);border:1px solid var(--border);border-radius:var(--radius);padding:8px 14px;display:flex;flex-direction:column;align-items:center;min-width:80px">' +
          '<div style="font-size:18px;font-weight:700;color:var(--primary)">' + v + '</div>' +
          '<div style="font-size:10px;color:var(--muted)">' + l + '</div></div>';
      }

      connectSSE(); refreshBreaker(); loadHealth();

      // ── Sandbox Lab ───────────────────────────────────────────────────────────
      let _sbCount = 0;

      function _sbStateColour(state) {
        return {
          proven: 'var(--success)', failed: 'var(--danger)', running: 'var(--warn)',
          blocked: 'var(--danger)', duplicate: 'var(--muted)', queued: 'var(--muted)'
        }[state] || 'var(--border)';
      }

      function buildSandboxCard(report) {
        const sc = _sbStateColour(report.state);
        const rScore = ((report.readiness_score || 0) * 100).toFixed(0);
        const iScore = ((report.impact_score || 0) * 100).toFixed(0);
        const dScore = ((report.difficulty_score || 0) * 100).toFixed(0);
        const conf = ((report.confidence || 0) * 100).toFixed(0);
        const dimHtml = (report.dimension_scores || []).map(d => {
          const fill = d.score >= 0.7 ? 'var(--success)' : d.score >= 0.4 ? 'var(--warn)' : 'var(--danger)';
          return '<div class="sb-dim-bar-wrap"><span style="color:var(--muted);min-width:84px">' + esc(d.name) + '</span>' +
            '<div class="sb-dim-bar"><div class="sb-dim-bar-fill" style="width:' + Math.round(d.score * 100) + '%;background:' + fill + '"></div></div>' +
            '<span style="min-width:26px;text-align:right;color:var(--text)">' + Math.round(d.score * 100) + '%</span></div>';
        }).join('');
        const el = document.createElement('div');
        el.id = 'sb-' + report.sandbox_id;
        el.className = 'sb-card';
        el.style.border = '1px solid ' + sc;
        el.innerHTML =
          '<div style="display:flex;align-items:flex-start;gap:14px;flex-wrap:wrap">' +
          '<div style="display:flex;flex-direction:column;align-items:center;min-width:68px;flex-shrink:0">' +
          '<div style="font-size:28px;font-weight:800;color:' + sc + '">' + rScore + '<span style="font-size:13px">%</span></div>' +
          '<div style="font-size:10px;color:var(--muted)">readiness</div>' +
          '<div style="font-size:11px;font-weight:700;color:' + sc + ';margin-top:4px">' + esc(report.state.toUpperCase()) + '</div>' +
          '</div>' +
          '<div style="flex:1;min-width:200px;display:flex;flex-direction:column;gap:6px">' +
          '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">' +
          '<strong style="font-size:13px">' + esc(report.feature_title) + '</strong>' +
          (report.roadmap_item_id ? '<span style="font-size:10px;font-family:var(--mono);color:var(--primary);background:var(--primary-dim);padding:1px 6px;border-radius:4px">' + esc(report.roadmap_item_id) + '</span>' : '') +
          '<span style="font-size:10px;padding:1px 6px;border-radius:4px;background:var(--primary-dim);color:var(--primary)">' + esc(report.intent) + '</span>' +
          '<span style="font-size:10px;color:var(--muted)">conf:' + conf + '%</span>' +
          '<span style="font-size:10px;color:' + (report.tribunal_passed ? 'var(--success)' : 'var(--danger)') + '">' + (report.tribunal_passed ? '\u2713 tribunal' : '\u2717 tribunal') + '</span>' +
          '<span style="font-size:10px;color:var(--muted)">' + esc(String(report.latency_ms)) + 'ms</span>' +
          '</div>' +
          '<div style="font-size:11px;color:var(--muted)">' + esc(report.scope_summary || '') + '</div>' +
          '<div style="display:flex;gap:16px;flex-wrap:wrap">' +
          '<div style="display:flex;flex-direction:column;align-items:center">' +
          '<div style="font-size:15px;font-weight:700;color:var(--primary)">' + iScore + '%</div>' +
          '<div style="font-size:10px;color:var(--muted)">impact</div></div>' +
          '<div style="display:flex;flex-direction:column;align-items:center">' +
          '<div style="font-size:15px;font-weight:700;color:var(--warn)">' + dScore + '%</div>' +
          '<div style="font-size:10px;color:var(--muted)">difficulty</div></div>' +
          '<div style="display:flex;flex-direction:column;align-items:center">' +
          '<div style="font-size:15px;font-weight:700;color:var(--text)">' + esc(String(report.timeline_days)) + 'd</div>' +
          '<div style="font-size:10px;color:var(--muted)">timeline</div></div>' +
          '</div>' +
          '</div>' +
          (dimHtml ? '<div style="flex:0 0 210px;display:flex;flex-direction:column;gap:4px;padding:8px 10px;background:var(--surface-alt);border-radius:6px;border:1px solid var(--border)">' + dimHtml + '</div>' : '') +
          '</div>' +
          ((report.recommendations && report.recommendations.length) ?
            '<div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border)">' +
            report.recommendations.slice(0, 2).map(r => '<div style="font-size:11px;color:var(--muted);margin-bottom:2px">\u27A4 ' + esc(r) + '</div>').join('') +
            '</div>' : '') +
          ((report.similar_sandboxes && report.similar_sandboxes.length) ?
            '<div style="margin-top:6px;font-size:11px;color:var(--muted)">' +
            '\u2248 Similar: ' + report.similar_sandboxes.map(s => '<span style="color:var(--primary)">' + esc(s.id) + '</span>').join(', ') +
            '</div>' : '');
        return el;
      }

      function addSandboxCard(report) {
        const existing = document.getElementById('sb-' + report.sandbox_id);
        if (existing) { existing.replaceWith(buildSandboxCard(report)); return; }
        document.getElementById('sandbox-empty').style.display = 'none';
        _sbCount++;
        const badge = document.getElementById('sandbox-badge');
        if (badge) { badge.style.display = ''; badge.textContent = _sbCount; }
        document.getElementById('sandbox-list').prepend(buildSandboxCard(report));
      }

      async function loadSandboxes() {
        try {
          const d = await (await fetch('/v2/sandbox')).json();
          const reports = d.reports || [];
          if (reports.length) {
            document.getElementById('sandbox-empty').style.display = 'none';
            document.getElementById('sandbox-list').innerHTML = '';
            reports.forEach(r => document.getElementById('sandbox-list').appendChild(buildSandboxCard(r)));
            _sbCount = reports.length;
            const badge = document.getElementById('sandbox-badge');
            if (badge) { badge.style.display = ''; badge.textContent = _sbCount; }
          }
        } catch (e) { console.error('loadSandboxes:', e); }
      }

      // Roadmap panel
      document.getElementById('roadmap-toggle-btn').addEventListener('click', () => {
        const p = document.getElementById('roadmap-panel');
        const showing = p.style.display !== 'none';
        p.style.display = showing ? 'none' : 'block';
        if (!showing) loadRoadmap();
      });

      async function loadRoadmap() {
        const loadingEl = document.getElementById('roadmap-loading');
        const contentEl = document.getElementById('roadmap-content');
        if (loadingEl) loadingEl.style.display = 'block';
        if (contentEl) contentEl.style.display = 'none';
        try {
          const d = await (await fetch('/v2/roadmap')).json();
          renderRoadmap(d);
        } catch (e) { if (loadingEl) loadingEl.textContent = 'Error: ' + e.message; }
      }

      function renderRoadmap(data) {
        const loadingEl = document.getElementById('roadmap-loading');
        const contentEl = document.getElementById('roadmap-content');
        if (!contentEl) return;
        if (loadingEl) loadingEl.style.display = 'none';
        contentEl.style.display = 'flex';
        const items = {};
        (data.items || []).forEach(i => { items[i.id] = i; });
        const waves = data.waves || [];
        const byPri = data.by_priority || {};
        const byStatus = data.by_status || {};
        const statusColour = s => ({ proven: 'var(--success)', sandbox: 'var(--warn)', promoted: 'var(--primary)', blocked: 'var(--danger)', failed: 'var(--danger)' }[s] || 'var(--border)');
        const rmStat = (v, l) => '<div style="background:var(--surface-card);border:1px solid var(--border);border-radius:var(--radius);padding:5px 10px;display:flex;flex-direction:column;align-items:center"><div style="font-size:14px;font-weight:700;color:var(--primary)">' + v + '</div><div style="font-size:10px;color:var(--muted)">' + esc(l) + '</div></div>';
        contentEl.innerHTML =
          '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px">' +
          rmStat(data.total_items, 'Items') + rmStat(data.wave_count, 'Waves') + rmStat(data.max_parallel, 'Max Parallel') +
          Object.entries(byPri).map(([k, v]) => rmStat(v, k)).join('') +
          Object.entries(byStatus).filter(([k]) => k !== 'queued').map(([k, v]) => rmStat(v, k)).join('') +
          '</div>' +
          waves.map((wave, wi) =>
            '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:4px">' +
            '<span style="font-size:10px;font-weight:700;color:var(--muted);font-family:var(--mono);min-width:42px">W' + (wi + 1) + '</span>' +
            wave.map((id, ni) => {
              const item = items[id] || {};
              const sc = statusColour(item.status);
              return (ni > 0 ? '<span style="color:var(--muted);padding:0 2px">‖</span>' : '') +
                '<div class="roadmap-item-box" style="border:1px solid ' + sc + '" title="' + esc(item.description || '') + '">' +
                '<div style="display:flex;align-items:center;gap:5px">' +
                '<span style="font-size:10px;font-weight:700;font-family:var(--mono);color:var(--primary)">' + esc(id) + '</span>' +
                '<span style="font-size:10px;color:' + sc + '">' + esc(item.status || 'queued') + '</span></div>' +
                '<div style="font-size:11px;color:var(--text);max-width:175px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + esc((item.title || '').slice(0, 32)) + '</div>' +
                (item.readiness_score ? '<div style="font-size:10px;color:var(--success)">' + (item.readiness_score * 100).toFixed(0) + '% ready \u00b7 ' + (item.timeline_days || 0) + 'd</div>' :
                  '<div style="font-size:10px;color:var(--muted)">' + esc(item.priority || '') + '</div>') +
                '</div>';
            }).join('') +
            '</div>' +
            (wi < waves.length - 1 ? '<div style="padding-left:50px;color:var(--muted);font-size:13px;margin-bottom:2px">↓</div>' : '')
          ).join('');
      }

      // Spawn panel
      document.getElementById('spawn-toggle-btn').addEventListener('click', () => {
        const p = document.getElementById('spawn-panel');
        p.style.display = p.style.display === 'none' ? 'block' : 'none';
        document.getElementById('spawn-status').textContent = '';
      });

      document.getElementById('do-spawn-btn').addEventListener('click', async () => {
        const title = document.getElementById('spawn-title-input').value.trim();
        const text = document.getElementById('spawn-text-input').value.trim();
        const statusEl = document.getElementById('spawn-status');
        if (!text) { statusEl.textContent = 'Feature description is required.'; return; }
        const btn = document.getElementById('do-spawn-btn');
        btn.disabled = true; statusEl.textContent = 'Spawning sandbox…';
        try {
          const resp = await fetch('/v2/sandbox/spawn', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ feature_text: text, feature_title: title }),
          });
          const data = await resp.json();
          if (data.report) {
            addSandboxCard(data.report);
            showView('sandbox');
            document.getElementById('spawn-panel').style.display = 'none';
            document.getElementById('spawn-title-input').value = '';
            document.getElementById('spawn-text-input').value = '';
            statusEl.textContent = '';
          }
        } catch (e) { statusEl.textContent = 'Error: ' + e.message; }
        btn.disabled = false;
      });

      // Run Roadmap
      document.getElementById('run-roadmap-btn').addEventListener('click', async () => {
        const btn = document.getElementById('run-roadmap-btn');
        btn.disabled = true; btn.textContent = '\u23F3 Running…';
        try {
          const resp = await fetch('/v2/roadmap/run', { method: 'POST' });
          const data = await resp.json();
          (data.reports || []).forEach(r => addSandboxCard(r));
          loadRoadmap();
        } catch (e) { alert('Roadmap run error: ' + e.message); }
        btn.disabled = false; btn.textContent = '\u25B6 Run Roadmap';
      });
    })();
  </script>
</body>

</html>